# Copia este archivo a backend/.env y completa los valores
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html (gratuito)
FRED_API_KEY=

# Finnhub: https://finnhub.io/register (free tier, solo titulares en vivo)
FINNHUB_API_KEY=

# SEC exige identificarse con un User-Agent con email de contacto
SEC_USER_AGENT=StockScreener personal tu-email@ejemplo.com
